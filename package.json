{
  "name": "bank-actualbudget-sync",
  "version": "1.0.0",
  "description": "Automated bank transaction sync to ActualBudget — multi-bank, Playwright-based",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:unit": "jest --selectProjects unit",
    "test:integration": "jest --selectProjects integration",
    "test:fixture": "jest --selectProjects fixture",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@actual-app/api": "26.3.0",
    "node-cron": "^3.0.3",
    "pino": "^9.6.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/node-cron": "^3.0.11",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  }
}
