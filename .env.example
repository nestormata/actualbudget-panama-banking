# ActualBudget connection
ACTUAL_SERVER_URL=http://actual-budget:5006
ACTUAL_PASSWORD=your-actual-budget-password
ACTUAL_SYNC_ID=your-budget-sync-id

# GlobalBank Panama credentials
GLOBALBANK_USER=your-globalbank-username
GLOBALBANK_PASS=your-globalbank-password

# Banco General credentials
BGENERAL_USER=your-bgeneral-username
BGENERAL_PASS=your-bgeneral-password
# Security Q&A: JSON array of { "pattern": "<regex>", "answer": "<answer>" }
# The connector logs the exact question text at info/warn level on each login —
# use those logs to craft or update the regex patterns here.
# Example (replace with your real answers — never commit this file):
# BGENERAL_SECURITY_QA=[{"pattern":"aniversario.*boda","answer":"..."},{"pattern":"escuela.*primaria","answer":"..."}]
BGENERAL_SECURITY_QA=[{"pattern":"pattern1","answer":"answer1"},{"pattern":"pattern2","answer":"answer2"}]

# Browser behavior (set to "false" to see the browser during debugging)
BROWSER_HEADLESS=true

# Logging (debug | info | warn | error)
LOG_LEVEL=info
