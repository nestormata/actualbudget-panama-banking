# ActualBudget connection
ACTUAL_SERVER_URL=http://actual-budget:5006
ACTUAL_PASSWORD=your-actual-budget-password
ACTUAL_SYNC_ID=your-budget-sync-id

# GlobalBank Panama credentials
GLOBALBANK_PA_USERNAME=your-username
GLOBALBANK_PA_PASSWORD=your-password

# Browser behavior (set to "false" to see the browser during debugging)
BROWSER_HEADLESS=true

# Logging (debug | info | warn | error)
LOG_LEVEL=info
